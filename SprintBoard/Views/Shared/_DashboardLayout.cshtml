<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SprintBoard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" />
    <style>
        :root {
            --sb-sidebar-w: 260px;
            --sb-sidebar-w-sm: 72px;
            --sb-topnav-h: 64px;
            --sb-bg: #0f172a;
            --sb-accent: #4361ee;
            --sb-page-bg: #f1f5f9;
        }

        *, *::before, *::after { box-sizing: border-box; }
        body { margin: 0; background: var(--sb-page-bg); font-family: system-ui, -apple-system, sans-serif; }

        /* ── SIDEBAR ── */
        .sb-sidebar {
            position: fixed; top: 0; left: 0;
            width: var(--sb-sidebar-w);
            height: 100vh;
            background: var(--sb-bg);
            display: flex; flex-direction: column;
            transition: width .25s cubic-bezier(.4,0,.2,1);
            z-index: 1000; overflow: hidden;
        }
        .sb-sidebar.collapsed { width: var(--sb-sidebar-w-sm); }

        .sb-brand {
            display: flex; align-items: center; gap: .875rem;
            padding: 1.125rem 1rem;
            border-bottom: 1px solid rgba(255,255,255,.06);
            flex-shrink: 0; white-space: nowrap;
        }
        .sb-logo-icon {
            min-width: 36px; width: 36px; height: 36px;
            background: var(--sb-accent); border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            font-size: .9rem; color: #fff;
        }
        .sb-logo-text { font-size: 1rem; font-weight: 700; color: #fff; }

        .sb-user-panel {
            display: flex; align-items: center; gap: .75rem;
            padding: .875rem 1rem;
            border-bottom: 1px solid rgba(255,255,255,.06);
            flex-shrink: 0; white-space: nowrap;
        }
        .sb-avatar {
            min-width: 38px; width: 38px; height: 38px;
            background: linear-gradient(135deg, #4361ee, #7209b7);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-weight: 700; font-size: .95rem; color: #fff;
        }
        .sb-user-name { font-size: .8rem; font-weight: 600; color: #e2e8f0; max-width: 150px; overflow: hidden; text-overflow: ellipsis; }
        .sb-user-info .badge { font-size: .6rem; margin-top: 2px; }

        .sb-nav { flex: 1; overflow-y: auto; padding: .5rem 0; scrollbar-width: thin; scrollbar-color: rgba(255,255,255,.08) transparent; }
        .sb-nav-label {
            padding: .75rem 1rem .2rem;
            font-size: .6rem; text-transform: uppercase; letter-spacing: .1em;
            color: rgba(255,255,255,.28); white-space: nowrap; overflow: hidden;
        }
        .sb-nav-link {
            display: flex; align-items: center; gap: .875rem;
            padding: .55rem .75rem; margin: 1px .5rem;
            border-radius: 8px; text-decoration: none;
            color: rgba(255,255,255,.62);
            font-size: .845rem; font-weight: 500;
            transition: all .15s; white-space: nowrap;
        }
        .sb-nav-link i { min-width: 20px; text-align: center; font-size: .875rem; }
        .sb-nav-link:hover { background: rgba(255,255,255,.07); color: #fff; }
        .sb-nav-link.active { background: var(--sb-accent); color: #fff; }

        .sb-footer {
            padding: .75rem;
            border-top: 1px solid rgba(255,255,255,.06);
            flex-shrink: 0;
        }
        .sb-logout-btn {
            width: 100%; display: flex; align-items: center; gap: .875rem;
            padding: .55rem .75rem;
            background: rgba(239,68,68,.1); border: none; border-radius: 8px;
            color: #fca5a5; font-size: .845rem; cursor: pointer;
            transition: all .15s; white-space: nowrap;
        }
        .sb-logout-btn:hover { background: rgba(239,68,68,.2); }
        .sb-logout-btn i { min-width: 20px; text-align: center; }

        /* Collapse: hide text */
        .sb-sidebar.collapsed .sb-logo-text,
        .sb-sidebar.collapsed .sb-user-info,
        .sb-sidebar.collapsed .sb-nav-label,
        .sb-sidebar.collapsed .sb-nav-link span,
        .sb-sidebar.collapsed .sb-logout-btn span { display: none; }
        .sb-sidebar.collapsed .sb-nav-link,
        .sb-sidebar.collapsed .sb-logout-btn { justify-content: center; gap: 0; }

        /* ── MAIN ── */
        .sb-main {
            margin-left: var(--sb-sidebar-w);
            min-height: 100vh; display: flex; flex-direction: column;
            transition: margin-left .25s cubic-bezier(.4,0,.2,1);
        }
        .sb-main.expanded { margin-left: var(--sb-sidebar-w-sm); }

        .sb-topnav {
            position: sticky; top: 0; z-index: 100;
            background: #fff; height: var(--sb-topnav-h);
            padding: 0 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
            box-shadow: 0 1px 0 #e2e8f0;
        }
        .sb-toggle {
            width: 36px; height: 36px;
            background: none; border: none; border-radius: 8px;
            color: #64748b; font-size: 1rem; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: all .15s;
        }
        .sb-toggle:hover { background: #f1f5f9; color: #0f172a; }
        .sb-page-title { font-size: .9rem; font-weight: 600; color: #0f172a; }

        .sb-profile-btn {
            display: flex; align-items: center; gap: .5rem;
            background: #f8fafc; border: 1px solid #e2e8f0;
            border-radius: 9px; padding: .35rem .75rem .35rem .4rem;
            font-size: .845rem; color: #374151; cursor: pointer;
            transition: all .15s;
        }
        .sb-profile-btn:hover { background: #f1f5f9; }
        .sb-profile-btn::after { display: none; }
        .sb-avatar-sm {
            width: 28px; height: 28px;
            background: linear-gradient(135deg, #4361ee, #7209b7);
            border-radius: 7px; display: flex; align-items: center;
            justify-content: center; color: #fff; font-weight: 700; font-size: .72rem;
        }

        .sb-content { flex: 1; padding: 1.5rem; }

        /* ── STAT CARDS ── */
        .stat-card {
            border: none; border-radius: 14px;
            padding: 1.25rem 1.5rem; color: #fff;
            position: relative; overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,.12);
        }
        .stat-card .s-icon {
            position: absolute; right: 1.25rem; top: 50%;
            transform: translateY(-50%);
            font-size: 2.8rem; opacity: .18;
        }
        .stat-card .s-value { font-size: 2rem; font-weight: 800; line-height: 1; }
        .stat-card .s-label { font-size: .78rem; opacity: .88; margin-top: .35rem; font-weight: 500; }
        .stat-blue   { background: linear-gradient(135deg,#4361ee,#3a0ca3); }
        .stat-amber  { background: linear-gradient(135deg,#f59e0b,#d97706); }
        .stat-green  { background: linear-gradient(135deg,#10b981,#059669); }
        .stat-red    { background: linear-gradient(135deg,#ef4444,#dc2626); }
        .stat-purple { background: linear-gradient(135deg,#8b5cf6,#7c3aed); }

        /* ── WELCOME BANNER ── */
        .welcome-banner {
            background: linear-gradient(135deg,#4361ee,#7209b7);
            border-radius: 14px; padding: 1.5rem 2rem;
            color: #fff; border: none;
            box-shadow: 0 4px 20px rgba(67,97,238,.25);
        }
        .welcome-banner h4 { font-size: 1.3rem; font-weight: 700; margin-bottom: .25rem; }
        .welcome-banner p  { opacity: .85; margin-bottom: 0; font-size: .9rem; }

        /* ── DASH CARDS ── */
        .dash-card {
            background: #fff; border: none;
            border-radius: 12px;
            box-shadow: 0 1px 4px rgba(0,0,0,.06);
        }
        .dash-card .card-header {
            background: none; border-bottom: 1px solid #f1f5f9;
            padding: 1rem 1.25rem;
            font-weight: 600; font-size: .875rem; color: #0f172a;
        }

        /* ── TABLE ── */
        .dash-table { margin-bottom: 0; }
        .dash-table thead th {
            font-size: .68rem; text-transform: uppercase; letter-spacing: .07em;
            color: #94a3b8; font-weight: 600;
            border-top: none; border-bottom-width: 1px;
            padding: .65rem 1.25rem; background: #f8fafc;
        }
        .dash-table td {
            padding: .75rem 1.25rem; vertical-align: middle;
            font-size: .855rem; color: #374151; border-color: #f1f5f9;
        }

        /* ── QUICK ACTIONS ── */
        .qa-btn {
            display: flex; align-items: center; gap: .75rem;
            padding: .7rem 1rem; border-radius: 10px;
            text-decoration: none; color: #374151;
            background: #f8fafc; border: 1px solid #e2e8f0;
            font-size: .845rem; font-weight: 500;
            transition: all .15s; margin-bottom: .5rem;
        }
        .qa-btn:last-child { margin-bottom: 0; }
        .qa-btn i { font-size: .875rem; width: 18px; text-align: center; color: var(--sb-accent); }
        .qa-btn:hover { background: var(--sb-accent); color: #fff; border-color: var(--sb-accent); }
        .qa-btn:hover i { color: #fff; }

        /* ── INFO ROWS (User dashboard) ── */
        .info-row {
            display: flex; justify-content: space-between; align-items: center;
            padding: .7rem 0; border-bottom: 1px solid #f1f5f9;
            font-size: .855rem;
        }
        .info-row:last-child { border-bottom: none; }
        .info-label { color: #94a3b8; font-weight: 500; }
        .info-value { color: #1e293b; font-weight: 600; text-align: right; }

        /* ── MOBILE OVERLAY ── */
        .sb-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.5); z-index: 999;
        }
        .sb-overlay.show { display: block; }

        @@media (max-width: 768px) {
            .sb-sidebar {
                transform: translateX(-100%);
                width: var(--sb-sidebar-w) !important;
                transition: transform .25s cubic-bezier(.4,0,.2,1), width 0s;
            }
            .sb-sidebar.mobile-open { transform: translateX(0); }
            .sb-main { margin-left: 0 !important; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div class="sb-overlay" id="sbOverlay"></div>

<!-- ══════════════ SIDEBAR ══════════════ -->
<aside class="sb-sidebar" id="sbSidebar">

    <div class="sb-brand">
        <div class="sb-logo-icon"><i class="fas fa-bolt"></i></div>
        <span class="sb-logo-text">SprintBoard</span>
    </div>

    <div class="sb-user-panel">
        <div class="sb-avatar">@(ViewBag.UserInitial ?? "U")</div>
        <div class="sb-user-info">
            <div class="sb-user-name">@(ViewBag.FullName ?? User.Identity?.Name)</div>
            @if (User.IsInRole("SuperAdmin"))
            {
                <span class="badge bg-danger">SuperAdmin</span>
            }
            else if (User.IsInRole("Admin"))
            {
                <span class="badge bg-warning text-dark">Admin</span>
            }
            else
            {
                <span class="badge bg-secondary">User</span>
            }
        </div>
    </div>

    <nav class="sb-nav">
        @if (User.IsInRole("SuperAdmin"))
        {
            <div class="sb-nav-label">Main Menu</div>
            <a href="@Url.Action("SuperAdmin", "Dashboard")" class="sb-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SuperAdmin" ? "active" : "")">
                <i class="fas fa-th-large"></i><span>Dashboard</span>
            </a>
            <div class="sb-nav-label">Management</div>
            <a href="@Url.Action("Index", "Users")" class="sb-nav-link">
                <i class="fas fa-users"></i><span>All Users</span>
            </a>
            <a href="@Url.Action("Create", "Users")" class="sb-nav-link">
                <i class="fas fa-user-plus"></i><span>Create User</span>
            </a>
            <div class="sb-nav-label">Account</div>
            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="sb-nav-link">
                <i class="fas fa-user-circle"></i><span>My Profile</span>
            </a>
        }
        else if (User.IsInRole("Admin"))
        {
            <div class="sb-nav-label">Main Menu</div>
            <a href="@Url.Action("Admin", "Dashboard")" class="sb-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Admin" ? "active" : "")">
                <i class="fas fa-th-large"></i><span>Dashboard</span>
            </a>
            <div class="sb-nav-label">Users</div>
            <a href="@Url.Action("Index", "Users")" class="sb-nav-link">
                <i class="fas fa-users"></i><span>My Users</span>
            </a>
            <a href="@Url.Action("Create", "Users")" class="sb-nav-link">
                <i class="fas fa-user-plus"></i><span>Create User</span>
            </a>
            <div class="sb-nav-label">Account</div>
            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="sb-nav-link">
                <i class="fas fa-user-circle"></i><span>My Profile</span>
            </a>
        }
        else
        {
            <div class="sb-nav-label">Main Menu</div>
            <a href="@Url.Action("UserDashboard", "Dashboard")" class="sb-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "UserDashboard" ? "active" : "")">
                <i class="fas fa-th-large"></i><span>Dashboard</span>
            </a>
            <div class="sb-nav-label">Account</div>
            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="sb-nav-link">
                <i class="fas fa-user-circle"></i><span>My Profile</span>
            </a>
            <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="sb-nav-link">
                <i class="fas fa-key"></i><span>Change Password</span>
            </a>
            <a asp-area="Identity" asp-page="/Account/Manage/TwoFactorAuthentication" class="sb-nav-link">
                <i class="fas fa-shield-alt"></i><span>Two-Factor Auth</span>
            </a>
        }
    </nav>

    <div class="sb-footer">
        <form method="post" asp-area="Identity" asp-page="/Account/Logout">
            <button type="submit" class="sb-logout-btn">
                <i class="fas fa-sign-out-alt"></i>
                <span>Sign Out</span>
            </button>
        </form>
    </div>

</aside>

<!-- ══════════════ MAIN ══════════════ -->
<div class="sb-main" id="sbMain">

    <header class="sb-topnav">
        <div class="d-flex align-items-center gap-3">
            <button class="sb-toggle" id="sbToggle" title="Toggle Sidebar">
                <i class="fas fa-bars"></i>
            </button>
            <span class="sb-page-title">@ViewData["Title"]</span>
        </div>

        <div class="dropdown">
            <button class="sb-profile-btn dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                <div class="sb-avatar-sm">@(ViewBag.UserInitial ?? "U")</div>
                <span class="d-none d-sm-inline ms-1">@(ViewBag.FullName ?? User.Identity?.Name)</span>
                <i class="fas fa-chevron-down ms-1" style="font-size:.65rem;color:#94a3b8"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="min-width:220px">
                <li class="px-3 pt-2 pb-1">
                    <div class="fw-semibold" style="font-size:.875rem">@(ViewBag.FullName ?? User.Identity?.Name)</div>
                    <div class="text-muted" style="font-size:.75rem">@User.Identity?.Name</div>
                </li>
                <li><hr class="dropdown-divider my-1"></li>
                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <i class="fas fa-user-circle me-2 text-muted" style="width:16px"></i>My Profile
                    </a>
                </li>
                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">
                        <i class="fas fa-key me-2 text-muted" style="width:16px"></i>Change Password
                    </a>
                </li>
                <li><hr class="dropdown-divider my-1"></li>
                <li>
                    <form method="post" asp-area="Identity" asp-page="/Account/Logout">
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="fas fa-sign-out-alt me-2" style="width:16px"></i>Sign Out
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </header>

    <main class="sb-content">
        @RenderBody()
    </main>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const sidebar  = document.getElementById('sbSidebar');
    const main     = document.getElementById('sbMain');
    const overlay  = document.getElementById('sbOverlay');
    const toggle   = document.getElementById('sbToggle');

    toggle.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
            sidebar.classList.toggle('mobile-open');
            overlay.classList.toggle('show');
        } else {
            sidebar.classList.toggle('collapsed');
            main.classList.toggle('expanded');
        }
    });

    overlay.addEventListener('click', () => {
        sidebar.classList.remove('mobile-open');
        overlay.classList.remove('show');
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
