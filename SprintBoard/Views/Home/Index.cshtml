@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "SprintBoard - Project & Task Management Platform";
}

<!-- 1. Hero Section -->
<section class="position-relative pt-5 pb-5 overflow-hidden bg-gradient-hero" style="margin-top: 80px;">
    <div class="container pt-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 text-center text-lg-start fade-in-up">
                <span class="badge badge-premium mb-3">
                    <i class="fa-solid fa-sparkles me-2"></i>Meet the Future of Work
                </span>
                <h1 class="hero-title text-body-emphasis mb-3">
                    Manage Projects Faster. <span class="text-primary">Deliver Results Smarter.</span>
                </h1>
                <p class="lead text-secondary-emphasis mb-4 fs-5">
                    SprintBoard helps teams plan projects, assign tasks, collaborate in real-time, and stay productive from start to finish.
                </p>
                <div class="d-flex flex-wrap justify-content-center justify-content-lg-start gap-3 mb-4">
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-premium-primary btn-lg shadow-sm">
                        Create Workspace <i class="fa-solid fa-arrow-right ms-2 text-xs"></i>
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-premium-secondary btn-lg">
                        Login
                    </a>
                </div>
                <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start gap-4 text-secondary-emphasis" style="font-size: 0.9rem;">
                    <div><i class="fa-solid fa-check text-success me-2"></i>No credit card required</div>
                    <div><i class="fa-solid fa-check text-success me-2"></i>Real-time collaboration</div>
                    <div><i class="fa-solid fa-check text-success me-2"></i>Secure authentication</div>
                </div>
            </div>
            
            <div class="col-lg-6 fade-in-up">
                <!-- Hero Dashboard Mockup -->
                <div class="dashboard-mockup shadow-lg">
                    <div class="mockup-header d-flex justify-content-between align-items-center">
                        <div class="d-flex">
                            <span class="dot-btn dot-red"></span>
                            <span class="dot-btn dot-yellow"></span>
                            <span class="dot-btn dot-green"></span>
                        </div>
                        <div class="text-xs text-secondary-emphasis fw-semibold"><i class="fa-solid fa-lock me-1"></i>sprintboard.app/workspace</div>
                        <div style="width: 40px;"></div>
                    </div>
                    <div class="mockup-body bg-body-tertiary">
                        <!-- Simulated Hero Dashboard Mini View -->
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="card border-0 shadow-sm rounded-3 p-3 h-100">
                                    <h6 class="text-xs text-uppercase tracking-wider text-muted mb-2">Project Progress</h6>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="project-progress-circle"></div>
                                        <div>
                                            <div class="fw-bold text-sm">Sprint 24</div>
                                            <span class="badge bg-success-subtle text-success text-xxs">On Track</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-6">
                                <div class="card border-0 shadow-sm rounded-3 p-3 h-100">
                                    <h6 class="text-xs text-uppercase tracking-wider text-muted mb-2">Team Members</h6>
                                    <div class="d-flex align-items-center">
                                        <div class="d-flex -space-x-2">
                                            <span class="avatar-placeholder bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width:32px; height:32px; font-size:10px; border:2px solid var(--sb-card-bg);">JD</span>
                                            <span class="avatar-placeholder bg-success text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width:32px; height:32px; font-size:10px; border:2px solid var(--sb-card-bg); margin-left:-8px;">EM</span>
                                            <span class="avatar-placeholder bg-warning text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width:32px; height:32px; font-size:10px; border:2px solid var(--sb-card-bg); margin-left:-8px;">SK</span>
                                            <span class="avatar-placeholder bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width:32px; height:32px; font-size:10px; border:2px solid var(--sb-card-bg); margin-left:-8px;">+4</span>
                                        </div>
                                        <div class="ms-3">
                                            <div class="text-xs text-muted">Active now</div>
                                            <div class="fw-semibold text-xs">7 developers</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="card border-0 shadow-sm rounded-3 p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="text-xs text-uppercase tracking-wider text-muted mb-0">Task Statuses</h6>
                                        <span class="text-xxs text-primary fw-bold">12 Tasks Due Today</span>
                                    </div>
                                    <div class="row g-2">
                                        <div class="col-4">
                                            <div class="p-2 bg-light-subtle rounded-2 text-center border">
                                                <div class="fw-bold text-sm text-primary">5</div>
                                                <div class="text-muted" style="font-size: 10px;">To Do</div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="p-2 bg-warning-subtle rounded-2 text-center border">
                                                <div class="fw-bold text-sm text-warning">4</div>
                                                <div class="text-muted" style="font-size: 10px;">In Progress</div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="p-2 bg-success-subtle rounded-2 text-center border">
                                                <div class="fw-bold text-sm text-success">18</div>
                                                <div class="text-muted" style="font-size: 10px;">Done</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 2. Trusted By Section -->
<section class="py-5 border-top border-bottom border-light-subtle bg-body-tertiary">
    <div class="container">
        <p class="text-center text-uppercase tracking-widest text-muted fw-bold mb-4" style="font-size: 0.8rem;">
            Trusted by fast-growing engineering teams worldwide
        </p>
        <div class="row justify-content-center align-items-center g-4 text-center">
            <div class="col-6 col-sm-4 col-md-2">
                <span class="trusted-logo"><i class="fa-brands fa-stripe me-2"></i>Stripe</span>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <span class="trusted-logo"><i class="fa-brands fa-slack me-2"></i>Slack</span>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <span class="trusted-logo"><i class="fa-brands fa-airbnb me-2"></i>Airbnb</span>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <span class="trusted-logo"><i class="fa-brands fa-uber me-2"></i>Uber</span>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <span class="trusted-logo"><i class="fa-brands fa-figma me-2"></i>Figma</span>
            </div>
        </div>
    </div>
</section>

<!-- 3. Features Section -->
<section id="features" class="py-5 bg-body-surface">
    <div class="container py-5">
        <div class="text-center max-w-xl mx-auto mb-5">
            <span class="badge badge-premium mb-2">Powerful Features</span>
            <h2 class="h1 fw-bold text-body-emphasis mb-3">Everything You Need to Scale Output</h2>
            <p class="text-secondary-emphasis fs-5">
                Built with modern enterprise-grade components, architectural design patterns, and responsive UX layouts.
            </p>
        </div>
        
        <div class="row g-4">
            <!-- 1. Project Management -->
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa-solid fa-diagram-project"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Project Management</h5>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Create multiple workspaces, structure sprints, define epics, and organize work portfolios inside dynamic backlogs.
                    </p>
                </div>
            </div>
            
            <!-- 2. Task Assignment -->
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa-solid fa-list-check"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Task Assignment</h5>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Easily assign tasks to individual contributors, set priorities, build dependency charts, and define due dates.
                    </p>
                </div>
            </div>
            
            <!-- 3. Team Collaboration -->
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Team Collaboration</h5>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Comment on cards, share documentation attachments, and tag team members to keep updates central to the task.
                    </p>
                </div>
            </div>
            
            <!-- 4. Real-Time Notifications -->
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa-solid fa-rss"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Real-Time (SignalR)</h5>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Simultaneous collaborative editing, updates, live progress trackers, and real-time in-app dashboard signals.
                    </p>
                </div>
            </div>
            
            <!-- 5. Role-Based Access Control -->
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Role-Based Access</h5>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Define secure roles (Admin, Manager, Member, Guest) and configure file permissions per project workspace.
                    </p>
                </div>
            </div>
            
            <!-- 6. Activity Tracking -->
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa-solid fa-chart-line"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Activity Tracking</h5>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Monitor active sprint velocity, check burndown charts, and analyze individual task completion speeds.
                    </p>
                </div>
            </div>
            
            <!-- 7. Smart Reporting -->
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Smart Reporting</h5>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Export robust data reports in CSV, PDF formats, or integrate custom dashboards with Microsoft PowerBI.
                    </p>
                </div>
            </div>
            
            <!-- 8. Background Automation -->
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa-solid fa-gears"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Automation (Hangfire)</h5>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Trigger background checkup jobs, automate recurring reports, and schedule notification cleanup cycles.
                    </p>
                </div>
            </div>
            
            <!-- 9. Secure Authentication -->
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa-solid fa-user-lock"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Secure Authentication</h5>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        ASP.NET Core Identity integration, two-factor authentication (2FA), SSO, OAuth logins (Google, AzureAD).
                    </p>
                </div>
            </div>
            
            <!-- 10. Audit Logs -->
            <div class="col-md-6 col-lg-4">
                <div class="feature-card">
                    <div class="feature-icon-wrapper">
                        <i class="fa-solid fa-clipboard-list"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Audit Logs</h5>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Maintain compliance logs tracing all administrative operations, membership adjustments, and state alterations.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 4. How It Works Section -->
<section id="how-it-works" class="py-5 bg-body-tertiary">
    <div class="container py-5">
        <div class="text-center max-w-xl mx-auto mb-5">
            <span class="badge badge-premium mb-2">Workflow</span>
            <h2 class="h1 fw-bold text-body-emphasis mb-3">Simplicity Meets Efficiency</h2>
            <p class="text-secondary-emphasis fs-5">
                Run projects without overhead using our optimized three-step workflow pattern.
            </p>
        </div>
        
        <div class="row g-4 text-center justify-content-center">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 rounded-3 step-card bg-body-surface">
                    <div class="step-num">01</div>
                    <div class="feature-icon-wrapper mx-auto mt-2">
                        <i class="fa-solid fa-compass"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Plan</h4>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Create projects, outline scope parameters, structure tasks, and define milestones for team guidance.
                    </p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 rounded-3 step-card bg-body-surface">
                    <div class="step-num">02</div>
                    <div class="feature-icon-wrapper mx-auto mt-2">
                        <i class="fa-solid fa-people-group"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Collaborate</h4>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Assign tasks, sync real-time comments, update status boards, and share attachments dynamically.
                    </p>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 rounded-3 step-card bg-body-surface">
                    <div class="step-num">03</div>
                    <div class="feature-icon-wrapper mx-auto mt-2">
                        <i class="fa-solid fa-trophy"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Deliver</h4>
                    <p class="text-secondary-emphasis text-sm mb-0">
                        Monitor visual progress dashboards, execute quality assurances, and release features efficiently.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 5. Dashboard Preview Section -->
<section id="dashboard-preview" class="py-5 bg-body-surface">
    <div class="container py-5">
        <div class="text-center max-w-xl mx-auto mb-5">
            <span class="badge badge-premium mb-2">Product Tour</span>
            <h2 class="h1 fw-bold text-body-emphasis mb-3">Live Interactive Operations Panel</h2>
            <p class="text-secondary-emphasis fs-5">
                Simulated real-time workspace experience displaying tasks, activity telemetry, and notification panels.
            </p>
        </div>
        
        <div class="row g-4 align-items-stretch">
            <!-- Main Dashboard Preview Card -->
            <div class="col-lg-8">
                <div class="dashboard-mockup h-100 shadow-lg">
                    <div class="mockup-header d-flex justify-content-between align-items-center">
                        <div class="d-flex">
                            <span class="dot-btn dot-red"></span>
                            <span class="dot-btn dot-yellow"></span>
                            <span class="dot-btn dot-green"></span>
                        </div>
                        <div class="text-xs text-secondary-emphasis fw-semibold">
                            <span class="badge bg-primary-subtle text-primary me-2"><i class="fa-solid fa-tower-broadcast me-1"></i>SignalR Active</span>
                            SprintBoard Workspace
                        </div>
                        <div>
                            <button class="btn btn-sm btn-link text-secondary-emphasis p-0" title="Settings"><i class="fa-solid fa-cog"></i></button>
                        </div>
                    </div>
                    
                    <div class="mockup-body bg-body-tertiary">
                        <!-- Simulated Stats Headers -->
                        <div class="row g-3 mb-4">
                            <div class="col-4">
                                <div class="card border-0 shadow-xs p-3">
                                    <div class="text-xs text-muted mb-1">Active Projects</div>
                                    <div class="fs-4 fw-bold">6</div>
                                    <div class="text-xs text-success"><i class="fa-solid fa-arrow-up me-1"></i>+2 this month</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="card border-0 shadow-xs p-3">
                                    <div class="text-xs text-muted mb-1">Pending Tasks</div>
                                    <div class="fs-4 fw-bold text-warning" id="pending-tasks-count">14</div>
                                    <div class="text-xs text-muted">Awaiting Action</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="card border-0 shadow-xs p-3">
                                    <div class="text-xs text-muted mb-1">Completed Tasks</div>
                                    <div class="fs-4 fw-bold text-success" id="completed-tasks-count">42</div>
                                    <div class="text-xs text-success"><i class="fa-solid fa-check me-1"></i>86% completion</div>
                                </div>
                            </div>
                        </div>

                        <!-- Progress Bar & Team Performance -->
                        <div class="card border-0 p-3 mb-4 shadow-xs">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-xs fw-bold text-muted">Team Task Performance</span>
                                <span class="text-xs fw-bold text-primary" id="task-progress-pct">75%</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div id="task-progress-bar" class="progress-bar progress-bar-striped progress-bar-animated bg-primary" role="progressbar" style="width: 75%;" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>

                        <!-- Task lists / Content Grid -->
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="card border-0 p-3 h-100 shadow-xs">
                                    <h6 class="fw-bold mb-3 text-xs text-uppercase tracking-wider text-muted">Active Work Items</h6>
                                    <div class="d-flex flex-column gap-2" style="font-size: 0.85rem;">
                                        <div class="p-2 border rounded bg-body-surface d-flex justify-content-between align-items-center">
                                            <span><i class="fa-solid fa-circle-check text-primary me-2"></i>Configure database index</span>
                                            <span class="badge bg-danger-subtle text-danger" style="font-size: 10px;">High</span>
                                        </div>
                                        <div class="p-2 border rounded bg-body-surface d-flex justify-content-between align-items-center">
                                            <span><i class="fa-solid fa-circle-play text-warning me-2"></i>Build API client routing</span>
                                            <span class="badge bg-warning-subtle text-warning" style="font-size: 10px;">Medium</span>
                                        </div>
                                        <div class="p-2 border rounded bg-body-surface d-flex justify-content-between align-items-center">
                                            <span><i class="fa-solid fa-circle-notch text-secondary me-2"></i>Setup unit testing suites</span>
                                            <span class="badge bg-secondary-subtle text-secondary" style="font-size: 10px;">Low</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="card border-0 p-3 h-100 shadow-xs">
                                    <h6 class="fw-bold mb-3 text-xs text-uppercase tracking-wider text-muted">Live Stream Timeline</h6>
                                    <div class="overflow-y-auto" style="max-height: 180px; font-size: 0.85rem;" id="activity-timeline">
                                        <!-- Real-Time Activity Simulators insert here -->
                                        <div class="d-flex align-items-start mb-3 border-bottom pb-2 border-light-subtle">
                                            <div class="bg-primary-subtle text-primary rounded-circle p-1 me-2 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.75rem;">
                                                <i class="fa-solid fa-bolt"></i>
                                            </div>
                                            <div class="flex-grow-1">
                                                <p class="mb-0 text-sm"><strong>Jane Doe</strong> completed task <span class="text-primary">Design landing page assets</span></p>
                                                <small class="text-muted text-xs">2 minutes ago</small>
                                            </div>
                                        </div>
                                        <div class="d-flex align-items-start mb-3 border-bottom pb-2 border-light-subtle">
                                            <div class="bg-primary-subtle text-primary rounded-circle p-1 me-2 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px; font-size: 0.75rem;">
                                                <i class="fa-solid fa-bolt"></i>
                                            </div>
                                            <div class="flex-grow-1">
                                                <p class="mb-0 text-sm"><strong>Evelyn Monroe</strong> created project <span class="text-primary">Q3 Product Marketing</span></p>
                                                <small class="text-muted text-xs">10 minutes ago</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Side Notifications and Action Panel -->
            <div class="col-lg-4">
                <div class="card border-1 h-100 shadow-sm p-4 bg-body-surface">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0"><i class="fa-solid fa-bell me-2 text-primary"></i>Live Alerts</h5>
                        <span class="badge rounded-pill bg-danger" id="notification-badge">2</span>
                    </div>
                    
                    <p class="text-muted text-xs mb-3">Live events pushed directly to client via SignalR connection streams.</p>
                    
                    <div id="mock-notifications" class="d-flex flex-column gap-2 mb-4">
                        <div class="alert alert-info py-2 px-3 mb-0 border-0 shadow-sm d-flex align-items-center justify-content-between" style="font-size: 0.85rem;">
                            <span><i class="fa-solid fa-bell me-2"></i> Server health check passed</span>
                            <span class="badge bg-secondary-subtle text-secondary-emphasis">1m ago</span>
                        </div>
                        <div class="alert alert-info py-2 px-3 mb-0 border-0 shadow-sm d-flex align-items-center justify-content-between" style="font-size: 0.85rem;">
                            <span><i class="fa-solid fa-bell me-2"></i> Hangfire job cleanup complete</span>
                            <span class="badge bg-secondary-subtle text-secondary-emphasis">5m ago</span>
                        </div>
                    </div>

                    <hr />

                    <h6 class="fw-bold text-xs text-uppercase tracking-wider text-muted mb-3">Quick Actions Simulation</h6>
                    <div class="d-flex flex-column gap-2">
                        <button class="btn btn-outline-primary btn-sm text-start" onclick="this.classList.add('disabled');"><i class="fa-solid fa-plus me-2"></i>Add Task Card</button>
                        <button class="btn btn-outline-primary btn-sm text-start" onclick="this.classList.add('disabled');"><i class="fa-solid fa-paper-plane me-2"></i>Push SignalR Event</button>
                        <button class="btn btn-outline-secondary btn-sm text-start" onclick="this.classList.add('disabled');"><i class="fa-solid fa-circle-nodes me-2"></i>Trigger Hangfire Job</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 6. Why Teams Choose SprintBoard Section -->
<section id="why-sprintboard" class="py-5 bg-body-tertiary">
    <div class="container py-5">
        <div class="text-center max-w-xl mx-auto mb-5">
            <span class="badge badge-premium mb-2">Why SprintBoard</span>
            <h2 class="h1 fw-bold text-body-emphasis mb-3">Why Teams Choose SprintBoard</h2>
            <p class="text-secondary-emphasis fs-5">
                Engineered to optimize collaborative velocity and improve deliverable predictability.
            </p>
