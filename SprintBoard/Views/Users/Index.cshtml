@model IEnumerable<SprintBoard.Models.UserListViewModel>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Users</h2>
        <a asp-action="Create" class="btn btn-primary">+ New User</a>
    </div>

    @if (TempData["Success"] is string msg)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @msg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Roles</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                var badgeClass = role switch
                                {
                                    "SuperAdmin" => "bg-danger",
                                    "Admin" => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                                <span class="badge @badgeClass me-1">@role</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@user.Id"
                               class="btn btn-sm btn-outline-primary">Edit</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">No users found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
