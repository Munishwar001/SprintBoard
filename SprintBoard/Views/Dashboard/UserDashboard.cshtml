@model SprintBoard.Models.UserDashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="welcome-banner mb-4">
    <h4>Welcome, @Model.FullName!</h4>
    <p>View your profile and manage your account settings.</p>
</div>

<div class="row g-3">

    <!-- Profile Summary -->
    <div class="col-lg-4">
        <div class="dash-card text-center p-4 h-100">
            <div class="mx-auto mb-3 d-flex align-items-center justify-content-center"
                 style="width:72px;height:72px;background:linear-gradient(135deg,#4361ee,#7209b7);border-radius:18px;font-size:2rem;font-weight:700;color:#fff">
                @Model.FullName.Substring(0, 1).ToUpper()
            </div>
            <h5 class="fw-bold mb-1">@Model.FullName</h5>
            <p class="text-muted mb-2" style="font-size:.875rem">@Model.Email</p>
            <span class="badge bg-secondary px-3 py-2">@Model.Role</span>
            <div class="mt-3">
                <a asp-area="Identity" asp-page="/Account/Manage/Index"
                   class="btn btn-outline-primary btn-sm">
                    <i class="fas fa-edit me-1"></i> Edit Profile
                </a>
            </div>
        </div>
    </div>

    <!-- Account Information -->
    <div class="col-lg-4">
        <div class="dash-card h-100">
            <div class="card-header">
                <i class="fas fa-info-circle me-2 text-muted"></i>Account Information
            </div>
            <div class="px-3 py-1">
                <div class="info-row">
                    <span class="info-label">Full Name</span>
                    <span class="info-value">@Model.FullName</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Email</span>
                    <span class="info-value" style="font-size:.8rem">@Model.Email</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Username</span>
                    <span class="info-value" style="font-size:.8rem">@Model.UserName</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Role</span>
                    <span class="info-value"><span class="badge bg-secondary">@Model.Role</span></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-lg-4">
        <div class="dash-card h-100">
            <div class="card-header">
                <i class="fas fa-bolt me-2 text-muted"></i>Quick Actions
            </div>
            <div class="p-3">
                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="qa-btn">
                    <i class="fas fa-user-circle"></i> View Profile
                </a>
                <a asp-area="Identity" asp-page="/Account/Manage/Email" class="qa-btn">
                    <i class="fas fa-envelope"></i> Update Email
                </a>
                <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="qa-btn">
                    <i class="fas fa-key"></i> Change Password
                </a>
                <a asp-area="Identity" asp-page="/Account/Manage/TwoFactorAuthentication" class="qa-btn">
                    <i class="fas fa-shield-alt"></i> Two-Factor Auth
                </a>
            </div>
        </div>
    </div>

</div>
