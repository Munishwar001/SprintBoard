@{
    ViewData["Title"] = "SuperAdmin Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">SuperAdmin Dashboard</h2>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-danger h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fs-2 fw-bold">@ViewBag.TotalUsers</div>
                        <div class="small">Total Users</div>
                    </div>
                    <i class="fas fa-users fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-dark bg-warning h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fs-2 fw-bold">@ViewBag.TotalAdmins</div>
                        <div class="small">Admins</div>
                    </div>
                    <i class="fas fa-user-shield fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-secondary h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fs-2 fw-bold">@ViewBag.TotalMembers</div>
                        <div class="small">Members</div>
                    </div>
                    <i class="fas fa-user fa-2x opacity-75"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold">Quick Actions</div>
                <div class="card-body d-flex flex-column gap-2">
                    <a asp-controller="Users" asp-action="Index" class="btn btn-outline-primary">Manage Users</a>
                    <a asp-controller="Users" asp-action="Create" class="btn btn-outline-success">Create User</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-semibold">Logged in as</div>
                <div class="card-body">
                    <p class="mb-1"><strong>@User.Identity!.Name</strong></p>
                    <span class="badge bg-danger">SuperAdmin</span>
                </div>
            </div>
        </div>
    </div>
</div>
